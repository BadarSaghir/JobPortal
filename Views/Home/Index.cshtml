@model Career635.Features.Jobs.Models.HomeViewModel
@{
    ViewData["Title"] = "Professional Career Gateway";
}

<!-- SECTION 1: IMPACT HERO -->
<section class="relative min-h-[85vh] flex items-center bg-secondary text-white overflow-hidden rounded-b-[4rem] shadow-2xl">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-[radial-gradient(circle_at_50%_50%,_var(--color-primary)_0%,_transparent_60%)] opacity-10 pointer-events-none"></div>
    
    <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-4xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold uppercase tracking-[0.2em] text-primary mb-8">
                <i data-lucide="shield-check" class="w-3 h-3"></i> Secure Personnel Portal
            </div>
            
            <h1 class="text-5xl md:text-8xl font-black tracking-tighter leading-[0.9] mb-8">
                Merit-Based <br/><span class="text-primary">Opportunities.</span>
            </h1>
            
            <p class="text-slate-400 text-lg md:text-xl font-light leading-relaxed mb-12 max-w-xl">
                Access specialized opportunities within our organization. We prioritize transparency, merit, and professional excellence.
            </p>

            <div class="flex flex-col md:flex-row items-stretch gap-4 max-w-3xl">
                <form asp-controller="Jobs" asp-action="Search" method="get" class="flex-1 bg-white p-1.5 rounded-2xl shadow-2xl flex items-center gap-2">
                    <div class="flex-1 flex items-center px-4 gap-3">
                        <i data-lucide="search" class="w-5 h-5 text-slate-300"></i>
                        <input name="searchTerm" type="text" placeholder="Search by job title..." class="w-full bg-transparent py-4 outline-none text-secondary font-bold placeholder:font-normal placeholder:text-slate-300" />
                    </div>
                    <button type="submit" class="bg-primary text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-emerald-400 transition-all">
                        Search
                    </button>
                </form>

                <div class="flex items-center gap-4 px-6 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md">
                    <div class="text-center">
                        <span class="block text-xl font-black text-primary leading-none">@Model.TotalActiveJobs</span>
                        <span class="text-[9px] text-slate-500 font-bold uppercase tracking-tighter">Live Roles</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECTION 2: CONTENT GRID -->
<section class="container mx-auto px-6 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        
        <!-- MAIN COLUMN: RECENT -->
        <div class="lg:col-span-8">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <h2 class="text-3xl font-black text-secondary tracking-tight">Open Vacancies</h2>
                    <div class="h-1 w-12 bg-primary mt-2 rounded-full"></div>
                </div>
                <a asp-controller="Jobs" asp-action="Search" class="group flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary hover:text-secondary transition-colors">
                    Explore All <i data-lucide="arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1"></i>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @foreach (var job in Model.RecentJobs) {
                    <partial name="_JobCard" model="job" />
                }
            </div>
        </div>

        <!-- SIDEBAR: GUIDE & URGENT -->
        <aside class="lg:col-span-4 space-y-8">
            <div class="bg-white rounded-[2.5rem] border border-slate-200 p-8 shadow-sm">
                <h3 class="text-sm font-black text-secondary uppercase tracking-widest mb-6 flex items-center gap-2">
                    <i data-lucide="help-circle" class="w-4 h-4 text-primary"></i> Application Guide
                </h3>
                <div class="space-y-6">
                    <div class="flex gap-4">
                        <span class="text-xs font-black text-primary bg-primary/10 w-6 h-6 flex items-center justify-center rounded-lg shrink-0">1</span>
                        <p class="text-xs text-slate-500 leading-relaxed">Complete the 8-page digital bio-data form with verified accuracy.</p>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-xs font-black text-primary bg-primary/10 w-6 h-6 flex items-center justify-center rounded-lg shrink-0">2</span>
                        <p class="text-xs text-slate-500 leading-relaxed">Upload a clear Passport Photo and professional PDF CV.</p>
                    </div>
                </div>
                <a asp-controller="Jobs" asp-action="Search" class="block w-full mt-8 bg-secondary text-white text-center py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-primary shadow-lg">
                    Find Job to Apply
                </a>
            </div>

            <!-- URGENT (LOCAL TIME AWARE) -->
            @if (Model.ExpiringJobs.Any())
            {
                <div class="bg-slate-900 rounded-[2.5rem] p-8 text-white sticky top-24 shadow-2xl">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="font-bold text-xs uppercase tracking-widest text-red-400">Closing Soon</h3>
                        <span class="flex h-2 w-2 rounded-full bg-red-500 animate-ping"></span>
                    </div>
                    <div class="space-y-6">
                        @foreach (var job in Model.ExpiringJobs) {
                            var hoursLeft = (int)(job.ExpiresAt - DateTime.Now).TotalHours;
                            <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="block group border-b border-white/5 pb-4 last:border-0 last:pb-0">
                                <h4 class="font-bold text-white group-hover:text-primary transition-colors text-sm">@job.Title</h4>
                                <span class="text-[10px] text-red-500 font-black mt-1 block uppercase">Ends in @hoursLeft Hours</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </aside>
    </div>
</section>

<!-- SECTION 3: TOOLS (SEARCHABLE TRACKING) -->
<section class="container mx-auto px-6 py-24 border-t border-slate-100">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
            <h2 class="text-4xl font-black text-secondary tracking-tighter">Track Your <br/>Application.</h2>
            <p class="text-slate-500 font-light leading-relaxed max-sm">Enter the code provided during your final submission to see real-time status.</p>
            
            <!-- TRACKING FORM FIXED -->
            <form asp-controller="Jobs" asp-action="Track" method="get" class="flex gap-2 max-w-md">
                <input name="code" type="text" placeholder="Identity Code (e.g. C635-XYZ)" class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-primary/20" />
                <button type="submit" class="bg-primary text-white px-6 py-3 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-secondary transition-all">Verify</button>
            </form>
        </div>

        <div class="bg-slate-50 rounded-[3rem] p-10 border border-slate-200">
            <h3 class="text-xl font-black text-secondary mb-2">Technical Support</h3>
            <p class="text-xs text-slate-400 mb-8 uppercase font-bold tracking-widest">Typical response time: &lt; 2 Hours</p>
            <form class="space-y-4">
                <input type="email" placeholder="Corporate Email Address" class="w-full bg-white border border-slate-200 rounded-xl p-4 text-sm outline-none" />
                <textarea rows="2" placeholder="Briefly describe the issue..." class="w-full bg-white border border-slate-200 rounded-xl p-4 text-sm outline-none resize-none"></textarea>
                <button type="button" class="w-full bg-secondary text-white py-4 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-primary transition-all">Submit Help Ticket</button>
            </form>
        </div>
    </div>
</section>