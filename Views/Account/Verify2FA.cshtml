@model Career635.Areas.Admin.Models.VerifyTwoFactorViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Security Challenge";
}

<div class="min-h-[85vh] flex items-center justify-center px-6">
    <div class="max-w-md w-full">
        
        <!-- IDENTITY HUD -->
        <div class="text-center mb-10">
            <div class="w-20 h-20 bg-slate-900 rounded-[2rem] flex items-center justify-center mx-auto mb-6 shadow-2xl border-2 border-emerald-500/20">
                <i data-lucide="shield-check" class="w-10 h-10 text-emerald-500"></i>
            </div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tighter uppercase leading-none">Security Challenge</h1>
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.3em] mt-3">Identity Verification Protocol</p>
        </div>

        <!-- CHALLENGE CARD -->
        <div class="bg-white rounded-[3rem] border border-slate-200 p-10 lg:p-14 shadow-2xl shadow-slate-200/60 relative overflow-hidden">
            <form asp-action="LoginWith2FA" method="post" class="space-y-8 relative z-10">
                <input type="hidden" asp-for="ReturnUrl" />
                <input type="hidden" asp-for="RememberMe" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-100 text-red-600 p-4 rounded-2xl text-[10px] font-black uppercase flex items-center gap-3 animate-in fade-in zoom-in duration-300">
                        <i data-lucide="alert-octagon" class="w-4 h-4"></i>
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="space-y-4 text-center">
                    <label class="text-[11px] font-black text-slate-500 uppercase tracking-widest">Enter 6-Digit Authenticator Code</label>
                    <input asp-for="VerificationCode" 
                           class="w-full bg-slate-50 border-none rounded-2xl py-6 text-center text-4xl font-mono font-black text-emerald-600 outline-none focus:ring-4 focus:ring-emerald-500/10 tracking-[0.4em]" 
                           placeholder="000000" 
                           maxlength="6" 
                           required 
                           autofocus 
                           autocomplete="one-time-code" />
                </div>

                <div class="flex items-center gap-3 bg-slate-50 p-4 rounded-2xl border border-slate-100">
                    <input asp-for="RememberDevice" type="checkbox" class="w-4 h-4 rounded border-slate-300 text-emerald-600 focus:ring-0" />
                    <label class="text-[11px] font-bold text-slate-600 uppercase tracking-tight cursor-pointer">Authorize this station for 30 days</label>
                </div>

                <button type="submit" class="w-full bg-slate-900 text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.3em] shadow-xl hover:bg-emerald-600 transition-all active:scale-95">
                    Verify Identity
                </button>
            </form>
            
            <!-- Decor -->
            <div class="absolute -bottom-10 -right-10 p-8 opacity-[0.03] pointer-events-none">
                <i data-lucide="key-round" class="w-48 h-48"></i>
            </div>
        </div>

        <p class="mt-10 text-center text-[10px] text-slate-400 font-bold uppercase tracking-widest leading-relaxed max-w-[280px] mx-auto">
            Authorized personnel only. Access attempts are monitored by the security unit.
        </p>
    </div>
</div>

