@model Career635.Features.Auth.Models.LoginViewModel
@{
    ViewData["Title"] = "Staff Authentication";
}

<div class="min-h-[80vh] flex items-center justify-center px-6">
    <div class="w-full max-w-md">
        
        <!-- BRANDING HEADLINE -->
        <div class="text-center mb-10">
            <div class="bg-secondary w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl shadow-secondary/20">
                <i data-lucide="shield-lock" class="w-8 h-8 text-white"></i>
            </div>
            <h1 class="text-3xl font-black text-secondary tracking-tighter uppercase">Personnel <span class="text-primary">Portal</span></h1>
            <p class="text-slate-400 text-sm mt-2 font-medium uppercase tracking-widest">Internal Access Only</p>
        </div>

        <!-- LOGIN CARD -->
        <div class="bg-white rounded-[2.5rem] border border-slate-200 p-10 shadow-2xl shadow-slate-200/60">
            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-8">
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-100 text-red-600 p-4 rounded-xl text-xs font-bold flex items-center gap-3 animate-in fade-in zoom-in duration-300">
                        <i data-lucide="alert-circle" class="w-4 h-4"></i>
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Organizational Email</label>
                        <div class="relative group">
                            <i data-lucide="mail" class="absolute left-0 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-300 group-focus-within:text-primary transition-colors"></i>
                            <input asp-for="Email" class="w-full bg-transparent border-b-2 border-slate-100 pl-8 py-3 outline-none focus:border-primary font-bold text-secondary transition-all" placeholder="name@organization.com" />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Security Password</label>
                        <div class="relative group">
                            <i data-lucide="key-round" class="absolute left-0 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-300 group-focus-within:text-primary transition-colors"></i>
                            <input asp-for="Password" class="w-full bg-transparent border-b-2 border-slate-100 pl-8 py-3 outline-none focus:border-primary font-bold text-secondary transition-all" placeholder="••••••••" />
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input asp-for="RememberMe" type="checkbox" class="w-4 h-4 rounded border-slate-300 text-primary focus:ring-primary/20" />
                        <span class="text-[11px] font-bold text-slate-500 uppercase tracking-tight group-hover:text-secondary transition-colors">Remember Station</span>
                    </label>
                    @* <a href="#" class="text-[11px] font-bold text-primary hover:underline uppercase tracking-tight">Recover Access</a> *@
                </div>

                <button type="submit" class="w-full bg-secondary text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.3em] shadow-xl shadow-secondary/20 hover:bg-primary transition-all hover:-translate-y-0.5 active:scale-95">
                    Authorized Entry
                </button>
            </form>
        </div>

        <!-- SECURITY NOTICE -->
        <div class="mt-10 flex items-center justify-center gap-3 text-slate-300">
            <div class="h-[1px] w-12 bg-slate-200"></div>
            <div class="flex items-center gap-2">
                <i data-lucide="lock" class="w-3 h-3"></i>
                <span class="text-[9px] font-black uppercase tracking-[0.2em]">Encrypted Session</span>
            </div>
            <div class="h-[1px] w-12 bg-slate-200"></div>
        </div>
        
        <p class="mt-6 text-center text-[10px] text-slate-400 leading-relaxed max-w-[280px] mx-auto uppercase font-bold">
            Unauthorized access attempts are logged and reported to the system security unit.
        </p>
    </div>
</div>