@model Career635.Features.Jobs.Models.SearchPageViewModel
@{
    ViewData["Title"] = "Search Opportunities";
}

<section class="bg-[#F8FAFC] min-h-screen pb-24">
    <!-- SUB-HEADER / SEARCH BAR -->
    <div class="bg-white border-b border-slate-200 pt-12 pb-12 shadow-sm">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl">
                <h1 class="text-4xl font-black text-slate-900 tracking-tighter mb-4">Explore Roles</h1>
                <p class="text-slate-500 font-light text-lg">
                    Discovered <span class="text-slate-900 font-bold">@Model.TotalCount</span> available positions 
                    @if(!string.IsNullOrEmpty(Model.SearchTerm)){ <span>matching "<span class="text-emerald-600 font-bold">@Model.SearchTerm</span>"</span> }
                </p>
                
                <form method="get" class="mt-8 flex flex-col md:flex-row gap-3">
                    <div class="flex-1 bg-slate-50 border border-slate-100 rounded-2xl flex items-center px-6 gap-4 focus-within:bg-white focus-within:ring-4 focus-within:ring-emerald-500/10 transition-all">
                        <i data-lucide="search" class="w-5 h-5 text-slate-300"></i>
                        <input name="searchTerm" value="@Model.SearchTerm" type="text" placeholder="Update search keywords..." 
                               class="w-full py-4 bg-transparent outline-none font-bold text-slate-700 placeholder:font-normal placeholder:text-slate-300" />
                    </div>
                    <button type="submit" class="bg-slate-900 text-white px-10 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-emerald-600 transition-all shadow-xl shadow-slate-200 active:scale-95">
                        Refine Results
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- RESULTS AREA -->
    <div class="container mx-auto px-6 mt-16">
        @if (!Model.Results.Any())
        {
            <div class="bg-white border border-slate-200 rounded-[3rem] p-20 text-center shadow-sm max-w-4xl mx-auto animate-in zoom-in duration-500">
                <div class="w-20 h-20 bg-slate-50 rounded-[2rem] flex items-center justify-center mx-auto mb-8">
                    <i data-lucide="search-x" class="w-10 h-10 text-slate-200"></i>
                </div>
                <h3 class="text-2xl font-black text-slate-900 mb-2">No matching dossiers found</h3>
                <p class="text-slate-400 max-w-xs mx-auto text-sm leading-relaxed mb-10">We couldn't find any vacancies matching your specific criteria. Try broader keywords.</p>
                <a href="/Search?searchTerm=" class="px-8 py-3 bg-emerald-50 text-emerald-600 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-emerald-100 transition-colors">Clear All Filters</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var job in Model.Results)
                {
                    <partial name="_JobCard" model="new Career635.Features.Jobs.Models.HomeJobViewModel(job.Id, job.Title, job.WorkLocation, job.LocationType, job.MinEducationLevel, job.RequiredExperienceYears, job.PostedAt, job.ExpiresAt)" />
                }
            </div>

            <!-- PAGINATION -->
            <div class="mt-20 flex flex-col items-center gap-6">
                <div class="flex items-center gap-2">
                    <!-- Previous -->
                    <a href="@Url.Action("Search", new { searchTerm = Model.SearchTerm, pageNumber = Model.PageNumber - 1 })" 
                       class="pag-btn @(Model.HasPreviousPage ? "" : "disabled")">
                        <i data-lucide="chevron-left" class="w-5 h-5"></i>
                    </a>

                    <!-- Page Numbers -->
                    <div class="flex items-center gap-2">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == Model.PageNumber)
                            {
                                <span class="w-12 h-12 rounded-2xl bg-emerald-600 text-white flex items-center justify-center font-black text-sm shadow-lg shadow-emerald-500/20">@i</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Search", new { searchTerm = Model.SearchTerm, pageNumber = i })" 
                                   class="w-12 h-12 rounded-2xl bg-white border border-slate-200 text-slate-400 hover:text-emerald-600 hover:border-emerald-600 flex items-center justify-center font-bold text-sm transition-all">@i</a>
                            }
                        }
                    </div>

                    <!-- Next -->
                    <a href="@Url.Action("Search", new { searchTerm = Model.SearchTerm, pageNumber = Model.PageNumber + 1 })" 
                       class="pag-btn @(Model.HasNextPage ? "" : "disabled")">
                        <i data-lucide="chevron-right" class="w-5 h-5"></i>
                    </a>
                </div>
                
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">
                    Displaying Page @Model.PageNumber of @Model.TotalPages
                </p>
            </div>
        }
    </div>
</section>

<style>
    .pag-btn { @@apply w-12 h-12 bg-white border border-slate-200 rounded-2xl flex items-center justify-center text-slate-400 hover:text-emerald-600 hover:border-emerald-600 transition-all shadow-sm; }
    .pag-btn.disabled { @@apply opacity-20 pointer-events-none grayscale bg-slate-50; }
</style>



