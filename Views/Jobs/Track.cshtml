@model Career635.Features.Jobs.Models.TrackViewModel
@{
    ViewData["Title"] = "Application Tracker";
}

<div class="bg-slate-50 min-h-[80vh] py-20">
    <div class="container mx-auto px-6 max-w-4xl">
        
        <!-- HEADER & SEARCH -->
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-black text-secondary tracking-tighter mb-4">Track Status</h1>
            <p class="text-slate-500 font-light mb-10">Enter your unique identity code to view recruitment progress.</p>
            
            <form method="get" asp-action="Track" class="max-w-xl mx-auto bg-white p-2 rounded-2xl shadow-2xl flex items-center gap-2">
                <div class="flex-1 flex items-center px-4 gap-3 py-2">
                    <i data-lucide="crosshair" class="w-5 h-5 text-slate-300"></i>
                    <input name="code" value="@Model.TrackingCode" type="text" placeholder="e.g. C635-D00002B9" class="w-full bg-transparent outline-none font-bold text-secondary uppercase placeholder:normal-case placeholder:font-normal" />
                </div>
                <button type="submit" class="bg-secondary text-white px-8 py-3 rounded-xl font-bold hover:bg-primary transition-all">Verify</button>
            </form>
        </div>

        @if (Model.Searched)
        {
            if (Model.Result != null)
            {
                <!-- SUCCESS: STATUS CARD -->
                <div class="bg-white rounded-[3rem] border border-slate-200 p-8 md:p-14 shadow-xl relative overflow-hidden animate-in fade-in slide-in-from-bottom-4 duration-700">
                    <div class="absolute top-0 right-0 p-8 opacity-[0.03] pointer-events-none">
                        <i data-lucide="shield-check" class="w-48 h-48"></i>
                    </div>

                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 pb-8 border-b border-slate-50 gap-6">
                        <div>
                            <span class="text-[10px] font-black text-primary uppercase tracking-[0.2em] mb-2 block">Dossier Tracking</span>
                            <h2 class="text-2xl font-black text-secondary leading-tight">@Model.Result.JobTitle</h2>
                            <p class="text-xs text-slate-400 font-bold mt-1">Applied on @Model.Result.AppliedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="px-6 py-3 bg-emerald-50 text-emerald-600 rounded-2xl border border-emerald-100 font-black text-xs uppercase tracking-widest">
                            @Model.Result.Status
                        </div>
                    </div>

                    <!-- VISUAL TIMELINE -->
                    <div class="relative px-4">
                        <div class="absolute left-8 top-0 bottom-0 w-[2px] bg-slate-100 hidden md:block"></div>
                        
                        <div class="space-y-12 relative z-10">
                            <!-- Step 1: Submission -->
                            <div class="flex gap-8 items-start">
                                <div class="w-8 h-8 rounded-lg bg-primary text-white flex items-center justify-center shrink-0 shadow-lg shadow-primary/20">
                                    <i data-lucide="check" class="w-4 h-4"></i>
                                </div>
                                <div>
                                    <h4 class="font-bold text-secondary text-sm">Application Received</h4>
                                    <p class="text-xs text-slate-400 mt-1">Your 8-page profile is encrypted and stored in our database.</p>
                                </div>
                            </div>

                            <!-- Step 2: Merit Review -->
                            @{ 
                                var isReviewed = Model.Result.Status != "Pending";
                                var isRejected = Model.Result.Status == "Rejected";
                            }
                            <div class="flex gap-8 items-start opacity-@(isReviewed ? "100" : "30")">
                                <div class="w-8 h-8 rounded-lg bg-@(isReviewed ? (isRejected ? "red-500" : "primary") : "slate-200") text-white flex items-center justify-center shrink-0">
                                    <i data-lucide="@(isRejected ? "x" : "search")" class="w-4 h-4"></i>
                                </div>
                                <div>
                                    <h4 class="font-bold text-secondary text-sm">Automated Merit Screening</h4>
                                    <p class="text-xs text-slate-400 mt-1">Comparison of qualifications against role specifications.</p>
                                </div>
                            </div>

                            <!-- Step 3: Interview -->
                            @{ var isInterviewed = Model.Result.Status == "Interviewed" || Model.Result.Status == "Offered"; }
                            <div class="flex gap-8 items-start opacity-@(isInterviewed ? "100" : "30")">
                                <div class="w-8 h-8 rounded-lg bg-@(isInterviewed ? "primary" : "slate-200") text-white flex items-center justify-center shrink-0">
                                    <i data-lucide="mic" class="w-4 h-4"></i>
                                </div>
                                <div>
                                    <h4 class="font-bold text-secondary text-sm">Personnel Interview</h4>
                                    <p class="text-xs text-slate-400 mt-1">Technical assessment and committee verification.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Result.Remarks))
                    {
                        <div class="mt-12 p-6 bg-slate-50 rounded-2xl border border-slate-100">
                            <h5 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Recruiter Remarks</h5>
                            <p class="text-xs text-slate-600 leading-relaxed italic">"@Model.Result.Remarks"</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- ERROR: CODE NOT FOUND -->
                <div class="bg-white rounded-[3rem] border border-slate-200 p-16 text-center shadow-sm animate-in zoom-in duration-500">
                    <div class="w-16 h-16 bg-red-50 rounded-2xl flex items-center justify-center mx-auto mb-6 text-red-500">
                        <i data-lucide="alert-circle" class="w-8 h-8"></i>
                    </div>
                    <h3 class="text-xl font-bold text-secondary mb-2">Invalid Tracking Identity</h3>
                    <p class="text-slate-400 max-w-xs mx-auto text-sm leading-relaxed">We couldn't find any submission associated with the code <strong>@Model.TrackingCode</strong>. Please check your spelling and try again.</p>
                </div>
            }
        }
    </div>
</div>