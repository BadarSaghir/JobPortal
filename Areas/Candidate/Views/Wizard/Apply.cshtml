    <div class="repeater-card border-l-emerald-500 bg-emerald-50/10" data-index="{idx}">
        <button type="button" onclick="removeRow(this, 'doc-container', 'DocumentAttachments')" 
                class="absolute top-3 right-3 text-red-400 hover:text-red-600 font-bold text-xs">REMOVE</button>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
            <div>
                <label class="section-label">Document Category *</label>
                <select name="DocumentAttachments[{idx}].DocumentType" class="form-input" required>
                    <option value="">-- Select Type --</option>
                    <option value="Education">Education (Degrees/Transcripts)</option>
                    <option value="Experience">Experience Letters</option>
                    <option value="Degree">Professional Degree</option>
                    <option value="Certificates">Certifications</option>
                </select>
            </div>
            <div>
                <label class="section-label">Select Files (Multiple Allowed) *</label>
                <input type="file" name="DocumentAttachments[{idx}].Files" 
                       class="form-input bg-white doc-file-input" 
                       multiple required 
                       accept=".pdf,.jpg,.jpeg,.png"
                       onchange="validateDocumentFiles(this)" />
                <div class="file-info-text text-[9px] mt-1 text-slate-400">Total size must be small (Max 50KB/file)</div>
            </div>
        </div>
    </div>
</template>
@section Scripts {
    <script>
        let currentStep = 1;

        // Reindex all rows inside a container (ensures sequential 0..n indices)
        function reindexContainer(containerId, baseName) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const rows = container.children;
            for (let i = 0; i < rows.length; i++) {
                const row = rows[i];
                // Update all input, select, textarea names inside the row
                row.querySelectorAll('input, select, textarea').forEach(el => {
                    const name = el.getAttribute('name');
                    if (name && name.startsWith(baseName + '[')) {
                        const newName = name.replace(/\[.*?\]/, `[${i}]`);
                        el.setAttribute('name', newName);
                    }
                });
                row.setAttribute('data-index', i);
            }
        }

        // Add a new row with the next sequential index
        function addDynamicRow(containerId, templateId, baseName) {
            const container = document.getElementById(containerId);
            const template = document.getElementById(templateId).innerHTML;
            const currentCount = container.children.length;
            const newRowHtml = template.replace(/{idx}/g, currentCount);
            container.insertAdjacentHTML('beforeend', newRowHtml);
            
            // Reinitialize datepickers and icons on the new row
            if (typeof flatpickr !== 'undefined') {
                flatpickr(".datepicker", { dateFormat: "Y-m-d", maxDate: "today" });
            }
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        }

        // Remove a row and reindex the remaining rows
        function removeRow(btn, containerId, baseName) {
            const row = btn.closest('.repeater-card');
            if (row) {
                row.remove();
                reindexContainer(containerId, baseName);
            } else {
                // For simple div rows (Skills, Certifications)
                const parentDiv = btn.parentElement;
                if (parentDiv && parentDiv.parentElement) {
                    parentDiv.remove();
                    reindexContainer(containerId, baseName);
                }
            }
        }
function validateFileSize(input) {
    const maxSize = 50 * 1024; // 50KB
    const files = input.files;
    
    for (let i = 0; i < files.length; i++) {
        if (files[i].size > maxSize) {
            alert(`File "${files[i].name}" is too large (${(files[i].size/1024).toFixed(2)}KB). Please upload files smaller than 50KB.`);
            input.value = ""; // Clear the input
            return;
        }
    }
}
function validateDocumentFiles(input) {
    const maxSize = 50 * 1024; // 50KB in bytes
    const files = input.files;
    let errorMsg = "";

    for (let i = 0; i < files.length; i++) {
        if (files[i].size > maxSize) {
            errorMsg = `File "${files[i].name}" exceeds the 50KB limit (${(files[i].size / 1024).toFixed(1)}KB).`;
            break;
        }
    }

    if (errorMsg) {
        alert(errorMsg);
        input.value = ""; // Clear selection
        input.classList.add('border-red-500');
    } else {
        input.classList.remove('border-red-500');
        // Optional: show count of files selected
        const label = input.parentElement.querySelector('.file-info-text');
        label.innerText = `${files.length} file(s) selected - Ready to upload`;
        label.classList.replace('text-slate-400', 'text-emerald-600');
    }
}
        $(document).ready(function() {
            // Ensure all dynamic containers are properly indexed on page load
            reindexContainer('sib-container', 'Siblings');
            reindexContainer('edu-container', 'Educations');
            reindexContainer('exp-container', 'Experiences');
            reindexContainer('skill-container', 'Skills');
            reindexContainer('cert-container', 'Certifications');
            reindexContainer('rel-container', 'InternalRelatives');
            reindexContainer('ach-container', 'Achievements');

            // WIZARD NAVIGATION
            $('.btn-next').click(function() {
                let isValid = true;
                $(`#step-${currentStep} input[required], #step-${currentStep} textarea[required]`).each(function() {
                    if (!$(this).val()) { $(this).addClass('input-validation-error'); isValid = false; } 
                    else { $(this).removeClass('input-validation-error'); }
                });

                if (isValid) {
                    $(`#step-${currentStep}`).removeClass('active');
                    currentStep++;
                    $(`#step-${currentStep}`).addClass('active');
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    lucide.createIcons();
                }
            });

            $('.btn-prev').click(function() {
                $(`#step-${currentStep}`).removeClass('active');
                currentStep--;
                $(`#step-${currentStep}`).addClass('active');
                lucide.createIcons();
            });

            // Initialize datepickers
            flatpickr(".datepicker", { dateFormat: "Y-m-d", maxDate: "today" });
            
            // Initialize FilePond
            FilePond.registerPlugin(FilePondPluginFileValidateSize, FilePondPluginFileValidateType);
            $('.filepond').each(function() { FilePond.create(this, { storeAsFile: true, maxFileSize: '2MB' }); });
            
            lucide.createIcons();


              reindexContainer('doc-container', 'DocumentAttachments');

    // Add a default row so the user sees it immediately
    if ($('#doc-container').children().length === 0) {
        addDynamicRow('doc-container', 'doc-template', 'DocumentAttachments');
    }

    // Update form submission to double-check file inputs
    @* $('#applicationForm').on('submit', function(e) {
        let valid = true;
        $('.doc-file-input').each(function() {
            if ($(this).prop('required') && $(this).get(0).files.length === 0) {
                valid = false;
                $(this).addClass('border-red-500');
            }
        });

        if (!valid) {
            e.preventDefault();
            alert("Please ensure all document categories have at least one file attached.");
        }
    }); *@
        });
    </script>
}