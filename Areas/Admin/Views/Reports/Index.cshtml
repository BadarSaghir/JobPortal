@model Career635.Areas.Admin.Models.ReportDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Merit Analytics";
}

<div class="space-y-10 pb-24">
    
    <!-- 1. DASHBOARD HEADER -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 no-print">
        <div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tighter uppercase leading-none">Merit Analytics</h1>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-3 border-l-2 border-emerald-500 pl-4">
                Personnel Acquisition Performance Data
            </p>
        </div>
        <button onclick="window.print()" class="flex items-center gap-3 px-8 py-4 bg-slate-900 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest shadow-xl hover:bg-emerald-600 transition-all active:scale-95">
            <i data-lucide="printer" class="w-4 h-4"></i> Generate Executive Summary
        </button>
    </div>

    <!-- 2. KPI STRIP -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var kpi in new[] {
            new { L = "Aggregate Dossiers", V = Model.TotalApplications, I = "database", C = "text-blue-500", B = "bg-blue-50" },
            new { L = "Merit Shortlist", V = Model.ShortlistedCount, I = "check-square", C = "text-emerald-500", B = "bg-emerald-50" },
            new { L = "Rejected Dossiers", V = Model.RejectedCount, I = "x-circle", C = "text-red-500", B = "bg-red-50" },
            new { L = "Awaiting Audit", V = Model.PendingCount, I = "clock", C = "text-amber-500", B = "bg-amber-50" }
        }) {
            <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200 shadow-sm relative overflow-hidden">
                <div class="flex justify-between items-start mb-4 relative z-10">
                    <div class="w-10 h-10 rounded-xl @kpi.B flex items-center justify-center @kpi.C">
                        <i data-lucide="@kpi.I" class="w-5 h-5"></i>
                    </div>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">@kpi.L</span>
                </div>
                <p class="text-4xl font-black text-slate-900 relative z-10">@kpi.V</p>
            </div>
        }
    </div>

    <!-- 3. VISUAL ANALYTICS -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        
        <!-- Acquisition Trend (Chart.js) -->
        <div class="lg:col-span-8 bg-white rounded-[3rem] border border-slate-200 p-10 lg:p-14 shadow-sm">
            <div class="flex justify-between items-center mb-12">
                <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-3">
                    <i data-lucide="line-chart" class="w-5 h-5 text-emerald-600"></i> Acquisition Velocity
                </h3>
                <span class="text-[9px] font-bold text-slate-400 uppercase bg-slate-50 px-3 py-1 rounded-full">Last 14 Days</span>
            </div>
            <div class="h-80">
                <canvas id="acqChart"></canvas>
            </div>
        </div>

        <!-- Education Profile -->
        <div class="lg:col-span-4 bg-white rounded-[3rem] border border-slate-200 p-10 shadow-sm">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-10">Academic Distribution</h3>
            <div class="space-y-8">
                @foreach (var edu in Model.EducationStats) {
                    <div class="space-y-3">
                        <div class="flex justify-between items-end">
                            <span class="text-[11px] font-black text-slate-700 uppercase tracking-tighter">@edu.Level</span>
                            <span class="text-[10px] font-mono font-bold text-slate-400">@edu.Count (@edu.Percentage.ToString("F1")%)</span>
                        </div>
                        <div class="h-2 w-full bg-slate-50 rounded-full overflow-hidden flex border border-slate-100">
                            <div class="h-full bg-emerald-500 rounded-full" style="width: @edu.Percentage%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 4. JOB ENGAGEMENT REGISTRY -->
    <div class="bg-white rounded-[3rem] border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-10 border-b border-slate-50 flex justify-between items-center">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Requisition Engagement (Top 5)</h3>
            <a href="/Admin/JobsAdmin" class="text-[10px] font-bold text-emerald-600 hover:underline uppercase tracking-widest">Explore All Registry &rarr;</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50/50">
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Official Designation</th>
                        <th class="px-6 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Dossiers Received</th>
                        <th class="px-6 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Lifecycle Status</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Merit Health</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var job in Model.TopPerformers) {
                        <tr class="hover:bg-slate-50/30 transition-colors">
                            <td class="px-10 py-6 text-sm font-black text-slate-800 uppercase tracking-tight">@job.Title</td>
                            <td class="px-6 py-6 text-center">
                                <span class="text-lg font-black text-slate-900">@job.Count</span>
                            </td>
                            <td class="px-6 py-6 text-xs font-bold text-slate-500 italic">@job.Status</td>
                            <td class="px-10 py-6 text-right">
                                <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[10px] font-black uppercase tracking-tighter">
                                    <i data-lucide="trending-up" class="w-3 h-3"></i> Optimal
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.min.js"></script>
    <script>
        // Data derived from .NET ViewModel
        const trendLabels = @Html.Raw(Json.Serialize(Model.AcquisitionTrend.Select(t => t.DateLabel)));
        const trendData = @Html.Raw(Json.Serialize(Model.AcquisitionTrend.Select(t => t.Count)));

        const ctx = document.getElementById('acqChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: trendLabels,
                datasets: [{
                    label: 'Submissions',
                    data: trendData,
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.05)',
                    borderWidth: 4,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#fff',
                    pointBorderWidth: 2,
                    pointBorderColor: '#10b981'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { 
                        beginAtZero: true,
                        grid: { color: '#f1f5f9' },
                        ticks: { font: { size: 10, weight: 'bold' }, color: '#94a3b8' }
                    },
                    x: { 
                        grid: { display: false },
                        ticks: { font: { size: 10, weight: 'bold' }, color: '#94a3b8' }
                    }
                }
            }
        });
    </script>
}