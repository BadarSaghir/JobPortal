@model Career635.Areas.Admin.Models.ApplicationReviewViewModel
@using Career635.Domain.Entities.Applicants
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dossier: " + Model.Applicant.FullName;
    var a = Model.Applicant;

    // Helper for secure file streaming
    string GetUrl(string? path) => string.IsNullOrEmpty(path) 
        ? "" 
        : Url.Action("GetFile", "Applications", new { area = "Admin", path = path }) ?? "";
}

<style>
    /* ENTERPRISE PRINT ENGINE */
    @@media print {
        /* Hide everything by default */
        body * { visibility: hidden !important; background: white !important; }
        /* Only show the Dossier Document */
        #dossier-document, #dossier-document * { visibility: visible !important; }
        #dossier-document { 
            position: absolute !important; 
            left: 0 !important; 
            top: 0 !important; 
            width: 100% !important; 
            margin: 0 !important; 
            padding: 0 !important; 
            border: none !important;
            box-shadow: none !important;
        }
        .no-print { display: none !important; }
        @@page { size: A4; margin: 1.5cm; }
    }

    /* Typographic Styles for the Professional CV */
    .cv-section-title { @@apply text-[11px] font-black text-emerald-800 uppercase tracking-[0.25em] border-b-2 border-emerald-100 pb-2 mb-8 mt-12 flex items-center gap-3; }
    .cv-label { @@apply text-[9px] font-bold text-slate-400 uppercase tracking-tighter block mb-1; }
    .cv-value { @@apply text-sm font-bold text-slate-800 leading-tight; }
</style>

<div class="flex flex-col xl:flex-row gap-10 min-h-screen -mt-10">
    
    <!-- LEFT: THE FORMAL PERSONNEL DOSSIER (Scrollable & Printable) -->
    <div class="flex-1 space-y-10 pb-32">
        
        <!-- UI TOOLBAR: HIDDEN ON PRINT -->
        <div class="no-print flex justify-between items-center bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
            <a href="/Admin/Applications" class="flex items-center gap-2 text-[10px] font-black text-slate-400 hover:text-emerald-600 transition-colors uppercase tracking-widest">
                <i data-lucide="chevron-left" class="w-4 h-4"></i> Back to Registry
            </a>
            <div class="flex items-center gap-4">
                <div class="px-4 py-2 bg-emerald-50 text-emerald-700 rounded-xl border border-emerald-100 text-[10px] font-black uppercase">
                    Status: @Model.Status
                </div>
                <button onclick="window.print()" class="flex items-center gap-2 px-6 py-2.5 bg-slate-900 text-white rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-600 transition-all shadow-lg">
                    <i data-lucide="printer" class="w-4 h-4"></i> Print Full Dossier
                </button>
            </div>
        </div>

        <!-- THE ACTUAL DOCUMENT CONTENT -->
        <div id="dossier-document" class="bg-white rounded-[3rem] border border-slate-200 shadow-2xl p-12 lg:p-20 relative overflow-hidden">
            
            <!-- Professional Watermark -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-[0.02] pointer-events-none rotate-[30deg]">
                <h1 class="text-[12rem] font-black uppercase tracking-widest">CONFIDENTIAL</h1>
            </div>

            <!-- HEADER SECTOR: Identity & Photo -->
            <div class="flex flex-col md:flex-row justify-between items-start gap-12 border-b-4 border-slate-900 pb-12 mb-12 relative z-10">
                <div class="flex-1 space-y-8">
                    <div>
                        <h1 class="text-5xl font-black text-slate-900 tracking-tighter uppercase leading-none">@a.FullName</h1>
                        <p class="text-sm font-bold text-emerald-600 uppercase tracking-[0.4em] mt-3 italic">Candidate Registry ID: @a.TrackingCode</p>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-y-6 gap-x-12 pt-4">
                        <div><label class="cv-label">National Identity (CNIC)</label><p class="cv-value font-mono">@a.CNICNumber</p></div>
                        <div><label class="cv-label">Application Post</label><p class="cv-value">@Model.JobTitle</p></div>
                        <div><label class="cv-label">Primary Contact</label><p class="cv-value">@a.PersonalInfo?.ContactNo</p></div>
                        <div><label class="cv-label">Email Record</label><p class="cv-value">@(a.PersonalInfo?.Email ?? "N/A")</p></div>
                    </div>
                </div>
                <div class="shrink-0 no-print">
                    <div class="w-44 h-52 bg-slate-50 border-4 border-white shadow-xl rounded-2xl overflow-hidden">
                        <img src="@GetUrl(a.PassportImageUrl)" class="w-full h-full object-cover" alt="Passport" />
                    </div>
                </div>
            </div>

            <!-- 01. PERSONAL PARTICULAR DOSSIER -->
            <section class="relative z-10">
                <h3 class="cv-section-title">01. Biographical Data</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-10">
                    <div><label class="cv-label">Father's Name</label><p class="cv-value">@a.PersonalInfo?.FatherName</p></div>
                    <div><label class="cv-label">Father's CNIC</label><p class="cv-value">@(a.PersonalInfo?.FatherCNIC ?? "Not Provided")</p></div>
                    <div><label class="cv-label">Date of Birth</label><p class="cv-value">@a.PersonalInfo?.DateOfBirth.ToString("dd MMM yyyy")</p></div>
                    <div><label class="cv-label">Gender/Marital</label><p class="cv-value">@a.PersonalInfo?.Gender / @a.PersonalInfo?.MaritalStatus</p></div>
                    <div><label class="cv-label">Religion/Sect</label><p class="cv-value">@a.PersonalInfo?.Religion / @(a.PersonalInfo?.Sect ?? "N/A")</p></div>
                    <div><label class="cv-label">PEC Registration</label><p class="cv-value">@(a.PersonalInfo?.PECNumber ?? "N/A")</p></div>
                    <div class="col-span-2"><label class="cv-label">Permanent Address</label><p class="text-xs font-bold text-slate-600">@a.PersonalInfo?.PermanentAddress</p></div>
                </div>
            </section>

            <!-- 02. ACADEMIC DOSSIER -->
            <section class="relative z-10">
                <h3 class="cv-section-title">02. Academic Attainments</h3>
                <div class="space-y-6">
                    @foreach (var edu in a.Educations.OrderByDescending(x => x.ToDate)) {
                        <div class="flex justify-between items-start border-b border-slate-50 pb-4">
                            <div>
                                <h4 class="text-sm font-black text-slate-900 uppercase">@edu.Qualification</h4>
                                <p class="text-[10px] font-bold text-slate-400">@edu.BoardUniversity</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-black text-emerald-600">@edu.CgpaPercentage</p>
                                <p class="text-[9px] font-bold text-slate-300 uppercase">Completed @edu.ToDate.Year</p>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- 03. PROFESSIONAL PORTFOLIO -->
            <section class="relative z-10">
                <h3 class="cv-section-title">03. Professional History</h3>
                <div class="space-y-10">
                    @foreach (var exp in a.Experiences.OrderByDescending(x => x.FromDate)) {
                        <div class="flex gap-8">
                            <div class="w-1 bg-emerald-100 rounded-full shrink-0"></div>
                            <div class="flex-1">
                                <div class="flex justify-between items-center mb-2">
                                    <h4 class="text-sm font-black text-slate-900 uppercase">@exp.Designation</h4>
                                    <span class="text-[9px] font-bold text-slate-400 uppercase">@exp.FromDate.ToString("MMM yyyy") — @(exp.ToDate?.ToString("MMM yyyy") ?? "PRESENT")</span>
                                </div>
                                <p class="text-xs font-bold text-emerald-700 mb-3">@exp.OrganizationName</p>
                                <p class="text-[11px] text-slate-500 leading-relaxed font-light italic bg-slate-50/50 p-4 rounded-xl border border-slate-100">
                                    @exp.KeyResponsibilities
                                </p>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- 04. SIBLINGS & MILITARY -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-16 relative z-10">
                <section>
                    <h3 class="cv-section-title">04. Family Context</h3>
                    <div class="space-y-4">
                        <div class="flex justify-between border-b border-slate-50 pb-2">
                            <span class="cv-label">Counts (B/S/C)</span>
                            <span class="text-xs font-black">@a.FamilySummary?.BrothersTotal / @a.FamilySummary?.SistersTotal / @a.FamilySummary?.ChildrenTotal</span>
                        </div>
                        @foreach(var s in a.Siblings) {
                            <div class="flex justify-between items-center">
                                <span class="text-xs font-bold text-slate-700">@s.Name</span>
                                <span class="text-[9px] font-bold text-slate-400 uppercase">@s.Occupation</span>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <h3 class="cv-section-title">05. Service Record</h3>
                    @if(!string.IsNullOrEmpty(a.MilitaryDetail?.ArmyNumber)) {
                        <div class="space-y-3 bg-slate-900 p-5 rounded-2xl text-white">
                            <div class="flex justify-between"><span class="text-[9px] font-black uppercase text-emerald-500">Service No.</span><span class="text-xs font-bold">@a.MilitaryDetail.ArmyNumber</span></div>
                            <div class="flex justify-between"><span class="text-[9px] font-black uppercase text-emerald-500">Corps/Unit</span><span class="text-xs font-bold">@a.MilitaryDetail.ArmyUnit</span></div>
                            <div class="flex justify-between"><span class="text-[9px] font-black uppercase text-emerald-500">Character</span><span class="text-xs font-bold">@a.MilitaryDetail.ArmyCharacter</span></div>
                        </div>
                    } else {
                        <p class="text-[11px] text-slate-400 italic">No military history recorded.</p>
                    }
                </section>
            </div>

            <!-- 06. FINANCIAL & EXTRAS -->
            <section class="mt-16 pt-10 border-t-2 border-slate-100 relative z-10">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                    <div><label class="cv-label">Current Salary</label><p class="cv-value">PKR @(a.FinancialDetail?.CurrentSalary?.ToString("N0") ?? "0")</p></div>
                    <div><label class="cv-label">Expected Salary</label><p class="cv-value text-emerald-600">PKR @(a.FinancialDetail?.ExpectedSalary?.ToString("N0") ?? "0")</p></div>
                    <div><label class="cv-label">Income Remarks</label><p class="text-xs text-slate-500 italic">@a.FinancialDetail?.FamilyIncomeDetail</p></div>
                </div>
            </section>

            <!-- PRINT-ONLY DISCLOSURE -->
            <div class="hidden print:block mt-24 text-center border-t border-slate-100 pt-10">
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Digitally Audited Personnel Snapshot — Career 635 Selection Board</p>
                <p class="text-[8px] text-slate-300 mt-2 uppercase">Official Record Generated: @DateTime.Now.ToString("dd-MMM-yyyy HH:mm")</p>
            </div>
        </div>
    </div>

    <!-- RIGHT: INTERACTIVE SIDEBAR (HIDDEN ON PRINT) -->
    <aside class="w-full xl:w-[500px] shrink-0 no-print">
        <div class="sticky top-28 space-y-6">
            
            <!-- 1. DECISION HUB -->
            <div class="bg-white rounded-[2.5rem] border border-slate-200 p-8 shadow-sm">
                <h3 class="text-[10px] font-black text-slate-900 uppercase tracking-[0.2em] mb-6">Merit Decision</h3>
                <form asp-action="UpdateStatus" method="post" class="space-y-4">
                    <input type="hidden" name="applicationId" value="@Model.ApplicationId" />
                    <select name="status" class="w-full bg-slate-50 border-none rounded-2xl px-5 py-4 text-sm font-bold text-slate-700 outline-none focus:ring-2 focus:ring-emerald-500/20">
                        <option value="Pending" selected="@(Model.Status == "Pending")">Pending Initial Audit</option>
                        <option value="Shortlisted" selected="@(Model.Status == "Shortlisted")">Shortlist for Interview</option>
                        <option value="Rejected" selected="@(Model.Status == "Rejected")">Reject Application</option>
                        <option value="Offered">Proceed to Offer</option>
                    </select>
                    <textarea name="remarks" rows="2" placeholder="Internal recruiter remarks..." class="w-full bg-slate-50 border-none rounded-2xl px-5 py-4 text-xs outline-none focus:ring-2 focus:ring-emerald-500/20 font-medium">@Model.RecruiterRemarks</textarea>
                    <button type="submit" class="w-full bg-secondary text-white py-5 rounded-2xl font-black text-[10px] uppercase tracking-[0.3em] shadow-xl hover:bg-primary transition-all active:scale-95">
                        Update Dossier Status
                    </button>
                </form>
            </div>

            <!-- 2. LIVE CV VIEWER -->
            <div class="bg-white rounded-[2.5rem] border border-slate-200 overflow-hidden shadow-2xl h-[700px] flex flex-col">
                <div class="px-8 py-4 bg-slate-50 border-b border-slate-100 flex justify-between items-center">
                    <div class="flex items-center gap-2">
                        <i data-lucide="file-text" class="w-4 h-4 text-emerald-600"></i>
                        <span class="text-[9px] font-black text-slate-900 uppercase tracking-widest">Digital PDF Portfolio</span>
                    </div>
                    <a href="@GetUrl(a.CvUrl)" target="_blank" download class="p-2 bg-emerald-600 text-white rounded-lg hover:bg-slate-900 shadow-lg shadow-emerald-200">
                        <i data-lucide="download" class="w-4 h-4"></i>
                    </a>
                </div>
                <div class="flex-1 bg-slate-800">
                    @if (!string.IsNullOrEmpty(a.CvUrl)) {
                        <iframe src="@GetUrl(a.CvUrl)#view=FitH&toolbar=0" class="w-full h-full border-none" 
                        type="application/pdf"
                        ></iframe>
                    } else {
                        <div class="h-full flex flex-col items-center justify-center text-slate-500">
                            <i data-lucide="file-x-2" class="w-12 h-12 mb-4 opacity-20"></i>
                            <p class="text-xs font-bold uppercase tracking-widest">PDF Portfolio Unavailable</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </aside>
</div>

