@model Career635.Areas.Admin.Models.EnableTwoFactorViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Security Hardening";
}

<div class="max-w-4xl mx-auto pb-20">
    <div class="flex items-center gap-4 mb-10">
        <a asp-action="Profile" class="p-2 bg-white border border-slate-200 rounded-xl text-slate-400 hover:text-emerald-600 transition-all">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <h1 class="text-3xl font-black text-slate-900 tracking-tighter uppercase">Initialize 2FA</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Step 1: QR Code -->
        <div class="bg-white rounded-[3rem] border border-slate-200 p-10 text-center shadow-sm">
            <div class="inline-block p-4 bg-slate-50 rounded-[2rem] border border-slate-100 mb-8">
                <img src="@Model.AuthenticatorUri" class="w-48 h-48 mix-blend-multiply" />
            </div>
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-4">Scan QR Code</h3>
            <p class="text-xs text-slate-500 leading-relaxed max-w-[240px] mx-auto">
                Open your Authenticator app (Google, Microsoft, or Authy) and scan this image to link your profile.
            </p>
        </div>

        <!-- Step 2: Verification -->
        <div class="bg-slate-900 rounded-[3rem] p-10 lg:p-14 text-white shadow-2xl relative overflow-hidden">
            <i data-lucide="key-round" class="absolute -right-4 -top-4 w-32 h-32 opacity-5"></i>
            
            <h3 class="text-[10px] font-black text-emerald-400 uppercase tracking-[0.3em] mb-10">Verification Protocol</h3>
            
            <form asp-action="Enable2FA" method="post" class="space-y-8 relative z-10">
                @Html.AntiForgeryToken()
                
                <div class="space-y-4">
                    <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Enter Generated 6-Digit Code</label>
                    <input asp-for="VerificationCode" required maxlength="6" class="w-full bg-white/5 border-b-2 border-white/10 py-4 text-center text-4xl font-mono font-black text-emerald-400 outline-none focus:border-emerald-500 tracking-[0.4em]" placeholder="000000" />
                    <span asp-validation-for="VerificationCode" class="text-red-400 text-[10px] font-bold"></span>
                </div>

                <div class="pt-6 border-t border-white/5">
                    <p class="text-[10px] text-slate-500 leading-relaxed uppercase font-bold tracking-tighter mb-8">
                        Manual Key: <span class="text-slate-300 select-all">@Model.SharedKey</span>
                    </p>
                    <button type="submit" class="w-full bg-emerald-600 text-white py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-white hover:text-slate-900 transition-all active:scale-95 shadow-xl shadow-emerald-500/10">
                        Authorize Authenticator
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>