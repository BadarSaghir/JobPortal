@model Career635.Areas.Admin.Models.UserProfileViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Personnel Dossier";
    
    // Helper to get first letter of name
    var initial = Model.FullName.Substring(0, 1).ToUpper();
}

<div class="max-w-6xl mx-auto space-y-10 pb-24">
    
    <!-- 1. BREADCRUMB & STATUS HEADER -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 no-print">
        <div class="space-y-1">
            <div class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">
                <span>Identity Registry</span>
                <i data-lucide="chevron-right" class="w-3 h-3 opacity-30"></i>
                <span class="text-emerald-600">Authorized Personnel</span>
            </div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tighter uppercase">My Profile</h1>
        </div>
        
        <div class="flex items-center gap-3 p-3 bg-white border border-slate-200 rounded-2xl shadow-sm">
            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
            <span class="text-[10px] font-black text-slate-700 uppercase tracking-widest">Active Node: SECURE-01</span>
        </div>
    </div>

    <!-- SUCCESS NOTIFICATION -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-emerald-50 border border-emerald-100 p-5 rounded-[1.5rem] text-emerald-700 text-xs font-bold flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
            <i data-lucide="check-circle" class="w-5 h-5"></i> @TempData["Success"]
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
        
        <!-- LEFT: BIO-DATA SIDEBAR (4 Units) -->
        <div class="lg:col-span-4 space-y-8">
            
            <!-- Identity Card -->
            <div class="bg-white rounded-[3rem] border border-slate-200 p-10 text-center shadow-sm relative overflow-hidden">
                <div class="absolute top-0 right-0 p-6 opacity-[0.03] pointer-events-none">
                    <i data-lucide="shield" class="w-32 h-32 text-slate-900"></i>
                </div>

                <div class="relative z-10">
                    <div class="w-28 h-28 rounded-[2rem] bg-slate-900 flex items-center justify-center text-primary text-4xl font-black mx-auto mb-8 shadow-xl shadow-slate-200">
                        @initial
                    </div>
                    <h2 class="text-2xl font-black text-slate-900 tracking-tighter uppercase">@Model.FullName</h2>
                    <p class="text-[11px] font-bold text-slate-400 mt-2 font-mono">@Model.Email</p>
                    
                    <div class="mt-8 pt-8 border-t border-slate-50 space-y-4">
                        <div class="flex flex-col items-center">
                            <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">Operator Since</span>
                            <span class="text-xs font-bold text-slate-700 mt-1">@Model.CreatedAt.ToString("MMMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Roles/Groups -->
            <div class="bg-slate-900 rounded-[2.5rem] p-8 text-white shadow-xl">
                <h3 class="text-[10px] font-black text-emerald-400 uppercase tracking-[0.2em] mb-6 flex items-center gap-2">
                    <i data-lucide="key" class="w-3 h-3"></i> Access Groups
                </h3>
                <div class="flex flex-wrap gap-2">
                    @foreach(var role in Model.Roles) {
                        <span class="px-3 py-1.5 bg-white/10 rounded-xl text-[9px] font-black uppercase tracking-tighter border border-white/5">@role</span>
                    }
                </div>
            </div>
        </div>

        <!-- RIGHT: ORGANIZATIONAL & SECURITY DETAILS (8 Units) -->
        <div class="lg:col-span-8 space-y-8">
            
            <!-- LOGISTICS PANEL -->
            <div class="bg-white rounded-[3rem] border border-slate-200 p-10 lg:p-14 shadow-sm relative overflow-hidden">
                <h3 class="text-[10px] font-black text-emerald-600 uppercase tracking-[0.3em] mb-12 flex items-center gap-3">
                    <i data-lucide="building-2" class="w-4 h-4"></i> Organizational Logistics
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                    <div class="space-y-1">
                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Official Designation</label>
                        <p class="text-base font-black text-slate-900 uppercase">@(Model.Designation ?? "Not Assigned")</p>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Assigned Unit</label>
                        <p class="text-base font-black text-slate-900 uppercase">@(Model.Department ?? "Headquarters")</p>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Personnel Grade</label>
                        <p class="text-base font-black text-slate-900 uppercase font-mono">@(Model.PayScale ?? "N/A")</p>
                    </div>
                </div>
            </div>

            <!-- SECURITY HARDENING (2FA) -->
            <div class="bg-white rounded-[3rem] border border-slate-200 p-10 lg:p-14 shadow-sm relative overflow-hidden">
                <div class="flex flex-col md:flex-row justify-between items-center gap-10">
                    <div class="flex items-center gap-8">
                        <div class="w-16 h-16 rounded-[1.5rem] @(Model.IsTwoFactorEnabled ? "bg-emerald-50 text-emerald-600 border-emerald-100" : "bg-red-50 text-red-500 border-red-100") border-2 flex items-center justify-center shrink-0">
                            <i data-lucide="@(Model.IsTwoFactorEnabled ? "shield-check" : "shield-alert")" class="w-8 h-8"></i>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-slate-900 uppercase tracking-tight">Two-Factor Authentication</h4>
                            <p class="text-xs text-slate-400 font-bold uppercase mt-1">
                                Secure Identity Verification: 
                                <span class="@(Model.IsTwoFactorEnabled ? "text-emerald-600" : "text-red-500")">
                                    @(Model.IsTwoFactorEnabled ? "ENFORCED" : "INACTIVE")
                                </span>
                            </p>
                        </div>
                    </div>

                    @if (Model.IsTwoFactorEnabled)
                    {
                        <form asp-action="Disable2FA" method="post" onsubmit="return confirm('Security Alert: Disabling 2FA reduces protection level. Continue?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="px-8 py-3 bg-white border border-slate-200 text-slate-400 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:text-red-600 hover:border-red-200 transition-all active:scale-95">
                                Disable Protection
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-action="Enable2FA" class="px-10 py-4 bg-slate-900 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-emerald-600 transition-all shadow-xl active:scale-95">
                            Harden Account Entry
                        </a>
                    }
                </div>
                
                @if (!Model.IsTwoFactorEnabled)
                {
                    <div class="mt-8 p-6 bg-slate-50 rounded-2xl border border-slate-100 flex gap-4">
                        <i data-lucide="info" class="w-4 h-4 text-emerald-600 shrink-0"></i>
                        <p class="text-[10px] text-slate-500 font-medium leading-relaxed uppercase">
                            Warning: Unauthorized personnel may attempt to breach sessions. Activating 2FA is highly recommended for all staff with "Personnel Dossier" access.
                        </p>
                    </div>
                }
            </div>

            <!-- SYSTEM PRIVILEGES CLOUD -->
            <div class="bg-white rounded-[3rem] border border-slate-200 p-10 lg:p-14 shadow-sm">
                <h3 class="text-[10px] font-black text-emerald-600 uppercase tracking-[0.3em] mb-12 flex items-center gap-3">
                    <i data-lucide="fingerprint" class="w-4 h-4"></i> System Authorization Matrix
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    @if (Model.Permissions != null && Model.Permissions.Any())
                    {
                        @foreach(var perm in Model.Permissions) {
                            <div class="flex items-center gap-4 p-5 bg-slate-50 rounded-2xl border border-slate-100 transition-all hover:border-emerald-200 group">
                                <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
                                <span class="text-[10px] font-black text-slate-600 uppercase tracking-tighter group-hover:text-slate-900">@perm</span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="col-span-2 text-xs text-slate-400 italic">No specific system permissions assigned to your role group.</p>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

