@model Career635.Areas.Admin.Models.NotificationIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "System Alerts Registry";
}

<div class="space-y-10 pb-20">
    <!-- 1. HEADER -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tighter uppercase leading-none">Security & System Alerts</h1>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Audit trail of automated notifications</p>
        </div>
        <form asp-action="MarkAllAsRead" method="post">
            <button type="submit" class="px-6 py-3 bg-white border border-slate-200 rounded-xl text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-emerald-600 hover:border-emerald-200 transition-all shadow-sm">
                Mark all as read
            </button>
        </form>
    </div>

    <!-- 2. FILTER BAR -->
    <form method="get" class="bg-white p-4 rounded-[2rem] border border-slate-200 shadow-sm flex flex-wrap items-center gap-4">
        <select name="type" class="bg-slate-50 border-none rounded-xl px-6 py-3 text-[10px] font-black uppercase text-slate-500 outline-none focus:ring-2 focus:ring-emerald-500/20">
            <option value="">All Categories</option>
            <option value="Info" selected="@(Model.TypeFilter == "Info")">Information</option>
            <option value="Success" selected="@(Model.TypeFilter == "Success")">Success</option>
            <option value="Urgent" selected="@(Model.TypeFilter == "Urgent")">Urgent</option>
        </select>

        <select name="isRead" class="bg-slate-50 border-none rounded-xl px-6 py-3 text-[10px] font-black uppercase text-slate-500 outline-none focus:ring-2 focus:ring-emerald-500/20">
            <option value="">All Statuses</option>
            <option value="false" selected="@(Model.ReadFilter == false)">Unread Only</option>
            <option value="true" selected="@(Model.ReadFilter == true)">Archive (Read)</option>
        </select>
        
        <button type="submit" class="px-8 py-3 bg-slate-900 text-white rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-600 transition-all">
            Update View
        </button>
    </form>

    <!-- 3. NOTIFICATION LIST -->
    <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden">
        <div class="divide-y divide-slate-50">
            @if (!Model.Items.Any())
            {
                <div class="p-20 text-center">
                    <i data-lucide="bell-off" class="w-12 h-12 text-slate-100 mx-auto mb-4"></i>
                    <p class="text-sm font-bold text-slate-300 uppercase tracking-widest">No alerts found in registry</p>
                </div>
            }
            @foreach (var n in Model.Items)
            {
                <div class="p-8 flex items-start gap-6 hover:bg-slate-50/50 transition-colors group @(n.IsRead ? "opacity-60" : "")">
                    <div class="mt-1">
                        @if (n.Type == "Urgent") {
                            <div class="w-10 h-10 rounded-xl bg-red-50 text-red-500 flex items-center justify-center border border-red-100"><i data-lucide="alert-triangle" class="w-5 h-5"></i></div>
                        } else if (n.Type == "Success") {
                            <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-500 flex items-center justify-center border border-emerald-100"><i data-lucide="check-circle" class="w-5 h-5"></i></div>
                        } else {
                            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center border border-blue-100"><i data-lucide="info" class="w-5 h-5"></i></div>
                        }
                    </div>
                    
                    <div class="flex-1 space-y-1">
                        <div class="flex justify-between items-start">
                            <h4 class="text-sm font-black text-slate-900 uppercase tracking-tight">@n.Title</h4>
                            <span class="text-[10px] font-mono font-bold text-slate-300">@n.TimeAgo</span>
                        </div>
                        <p class="text-sm text-slate-500 font-light leading-relaxed">@n.Message</p>
                        <div class="pt-4 flex items-center gap-4">
                            @if (!string.IsNullOrEmpty(n.ActionUrl)) {
                                <a href="@n.ActionUrl" class="text-[10px] font-black text-emerald-600 uppercase tracking-widest hover:underline flex items-center gap-1">
                                    Execute Action <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </a>
                            }
                            @if (!n.IsRead) {
                                <button class="text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-slate-900">Mark as Read</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- 4. PAGINATION -->
        <div class="px-10 py-6 bg-slate-50/50 border-t border-slate-100 flex justify-between items-center">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Showing @Model.Items.Count() of @Model.TotalCount Alerts</p>
            <div class="flex gap-2">
                <a href="@Url.Action("Notifications", new { type = Model.TypeFilter, isRead = Model.ReadFilter, page = Model.PageNumber - 1 })" 
                   class="pag-btn @(Model.HasPreviousPage ? "" : "disabled")">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                </a>
                <a href="@Url.Action("Notifications", new { type = Model.TypeFilter, isRead = Model.ReadFilter, page = Model.PageNumber + 1 })" 
                   class="pag-btn @(Model.HasNextPage ? "" : "disabled")">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<style>2
    .pag-btn { @@apply w-10 h-10 bg-white border border-slate-200 rounded-xl flex items-center justify-center text-slate-400 hover:border-emerald-600 hover:text-emerald-600 transition-all shadow-sm; }
    .pag-btn.disabled { @@apply opacity-20 pointer-events-none grayscale bg-slate-50; }
</style>