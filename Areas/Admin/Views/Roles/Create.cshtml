@model Career635.Areas.Admin.Models.CreateRoleViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Define Privilege Group";
    var groups = (IEnumerable<Career635.Areas.Admin.Models.PermissionGroupDto>)ViewBag.PermissionGroups;
}

<form asp-action="Create" method="post" class="max-w-7xl mx-auto pb-32">
    @Html.AntiForgeryToken()

    <!-- HEADER -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 mb-12 sticky top-20 z-40 bg-slate-50/90 backdrop-blur-md py-6 border-b border-slate-200/50">
        <div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tighter uppercase leading-none">New Privilege Group</h1>
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.3em] mt-3">Access Control Definition Protocol</p>
        </div>
        <div class="flex items-center gap-4">
            <a href="/Admin/Dashboard" class="text-[10px] font-black uppercase text-slate-400">Abort</a>
            <button type="submit" class="px-10 py-4 bg-emerald-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl shadow-emerald-200 hover:bg-slate-900 transition-all">
                Authorize Role
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1  gap-12 items-start">
        
        <!-- LEFT: ROLE BASICS (5 Units) -->
        <div class="lg:col-span-5 space-y-10">
            <div class="bg-white rounded-[3.5rem] border border-slate-200 p-10 lg:p-14 shadow-sm relative overflow-hidden">
                <h3 class="text-[10px] font-black text-emerald-600 uppercase tracking-[0.3em] mb-12">01. Role Particulars</h3>
                
                <div class="space-y-8">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Role Name / Identity*</label>
                        <input asp-for="Name" required class="w-full border-b-2 border-slate-100 py-3 outline-none focus:border-emerald-500 font-black text-slate-800 text-2xl transition-all" placeholder="e.g. Senior_Recruiter" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Scope Description</label>
                        <textarea asp-for="Description" rows="4" class="w-full bg-slate-50 rounded-2xl p-6 text-sm outline-none focus:ring-2 focus:ring-emerald-500/10 transition-all font-medium text-slate-600" placeholder="Define the operational boundaries for this group..."></textarea>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl relative overflow-hidden">
                <i data-lucide="shield-check" class="absolute -right-4 -top-4 w-32 h-32 opacity-5"></i>
                <h4 class="text-xs font-black uppercase text-emerald-400 mb-4 relative z-10">Security Notice</h4>
                <p class="text-[11px] text-slate-400 leading-relaxed font-light relative z-10 uppercase tracking-tight">
                    Permissions assigned here grant instant access to all users within this group. Changes are logged in the primary system audit trail.
                </p>
            </div>
        </div>

        <!-- RIGHT: PERMISSION MATRIX (7 Units) -->
        <div class="lg:col-span-7">
            <div class="bg-white rounded-[3.5rem] border border-slate-200 p-10 lg:p-14 shadow-sm">
                <h3 class="text-[10px] font-black text-emerald-600 uppercase tracking-[0.3em] mb-12">02. Privilege Matrix</h3>

                <div class="space-y-12">
                    @foreach (var group in groups)
                    {
                        <div>
                            <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest mb-6 border-l-4 border-emerald-500 pl-4 bg-slate-50 py-2">
                                @group.Module System
                            </h4>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                @foreach (var perm in group.Permissions)
                                {
                                    <label class="flex items-center justify-between p-5 rounded-2xl border border-slate-100 bg-white hover:border-emerald-200 hover:bg-emerald-50/30 transition-all cursor-pointer group">
                                        <div>
                                            <p class="text-xs font-black text-slate-700 uppercase tracking-tight">@perm.DisplayName</p>
                                            <p class="text-[9px] font-mono text-slate-400 group-hover:text-emerald-600 transition-colors">@perm.Name</p>
                                        </div>
                                        <input type="checkbox" name="SelectedPermissionIds" value="@perm.Id" class="w-5 h-5 rounded border-slate-300 text-emerald-600 focus:ring-0" />
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</form>